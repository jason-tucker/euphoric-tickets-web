# --- Database -------------------------------------------------------------
# In production the docker-compose service overrides this to talk to the
# `db` container directly. Leave the placeholder here so local dev (outside
# Docker) won't crash before you point it somewhere.
DATABASE_URL=postgresql://tickets_web:CHANGE_ME@localhost:5432/tickets_web

# --- Auth.js --------------------------------------------------------------
# 32+ random bytes, base64. Generate with: openssl rand -base64 32
AUTH_SECRET=

# In production: https://tickets.euphoric.fm
# In local dev:  http://localhost:3000
AUTH_URL=http://localhost:3000

# Trust the X-Forwarded-* headers Caddy sends. Required when the app is
# behind a reverse proxy (production), no-op otherwise.
AUTH_TRUST_HOST=true

# --- Discord OAuth --------------------------------------------------------
# Same Discord application as the bot is fine, OR a new one — what matters
# is that the OAuth redirect URL is registered:
#   https://tickets.euphoric.fm/api/auth/callback/discord
#   http://localhost:3000/api/auth/callback/discord  (for dev)
AUTH_DISCORD_ID=
AUTH_DISCORD_SECRET=

# --- Postgres (docker compose) --------------------------------------------
POSTGRES_PASSWORD=

# --- Image tag (set by CI; override locally for dev) ----------------------
WEB_IMAGE=ghcr.io/jason-tucker/euphoric-tickets-web:latest
